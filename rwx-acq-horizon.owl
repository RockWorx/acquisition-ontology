Prefix(:=<https://w3id.org/rockworx/acq/horizon#>)
Prefix(cco:=<https://www.commoncoreontologies.org/>)
Prefix(obo:=<http://purl.obolibrary.org/obo/>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(prov:=<http://www.w3.org/ns/prov#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(rwxa:=<https://w3id.org/rockworx/acq#>)
Prefix(rwxh:=<https://w3id.org/rockworx/acq/horizon#>)
Prefix(rwxt:=<https://w3id.org/rockworx/acq/transform#>)
Prefix(skos:=<http://www.w3.org/2004/02/skos/core#>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)


Ontology(<https://w3id.org/rockworx/acq/horizon>
<https://w3id.org/rockworx/acq/horizon/2026-07-19>
Import(<https://w3id.org/rockworx/acq>)
Import(<https://w3id.org/rockworx/acq/transform>)
Annotation(dcterms:creator "RockWorx Aerospace")
Annotation(dcterms:description "The legislative-horizon overlay: prospective, non-asserted candidate changes to the DoD acquisition system, extracted from real congressional instruments and tagged with legislative maturity, a sourced likelihood judgment, and an impact assessment. Strictly separated from the asserted base and transform modules -- prospective is never asserted as fact.")
Annotation(dcterms:license <https://opensource.org/licenses/BSD-3-Clause>)
Annotation(dcterms:title "RockWorx Acquisition Legislative-Horizon Overlay")
Annotation(rdfs:label "RockWorx Acquisition Legislative-Horizon Overlay")
Annotation(owl:versionInfo "2026-07-19")
Annotation(skos:definition "The legislative-horizon overlay: prospective, non-asserted candidate changes to the DoD acquisition system, extracted from real congressional instruments; strictly separated from the asserted base and transform modules.")

Declaration(Class(rwxh:LegislativeCandidateChange))
Declaration(Class(rwxh:LegislativeInstrument))
Declaration(ObjectProperty(prov:wasDerivedFrom))
Declaration(ObjectProperty(rwxh:wouldAffect))
Declaration(NamedIndividual(rwxt:DASReform2025))
Declaration(NamedIndividual(rwxt:ExecutiveOrder14265))
Declaration(NamedIndividual(rwxt:establishedPortfolioAcquisitionExecutives))
Declaration(NamedIndividual(rwxt:reorganizedProgramExecutiveOffices))
Declaration(AnnotationProperty(dcterms:date))
Declaration(AnnotationProperty(rwxh:changeType))
Declaration(AnnotationProperty(rwxh:enactmentLikelihood))
Declaration(AnnotationProperty(rwxh:graduatedTo))
Declaration(AnnotationProperty(rwxh:impactAssessment))
Declaration(AnnotationProperty(rwxh:legislativeMaturity))
Declaration(AnnotationProperty(rwxh:likelihoodBasis))
Declaration(AnnotationProperty(rwxh:prospectiveAuthorityTier))
############################
#   Annotation Properties
############################

# Annotation Property: rwxh:changeType (change type)

AnnotationAssertion(obo:IAO_0000115 rwxh:changeType "What the proposal would do to the referenced construct if enacted: ADD | MODIFY | SUPERSEDE.")
AnnotationAssertion(rdfs:label rwxh:changeType "change type")
AnnotationAssertion(skos:definition rwxh:changeType "What the proposal would do to the referenced construct if enacted: ADD | MODIFY | SUPERSEDE.")

# Annotation Property: rwxh:enactmentLikelihood (enactment likelihood)

AnnotationAssertion(obo:IAO_0000115 rwxh:enactmentLikelihood "An explicit, sourced JUDGMENT of the likelihood the proposal is enacted: LOW | MEDIUM | HIGH. This is a judgment, NEVER a fact; it is an annotation and is invisible to the reasoner. It must always be paired with a likelihoodBasis.")
AnnotationAssertion(rdfs:label rwxh:enactmentLikelihood "enactment likelihood")
AnnotationAssertion(skos:definition rwxh:enactmentLikelihood "An explicit, sourced judgment (LOW | MEDIUM | HIGH) of the likelihood of enactment; a judgment, never a fact.")

# Annotation Property: rwxh:graduatedTo (graduated to)

AnnotationAssertion(obo:IAO_0000115 rwxh:graduatedTo "On enactment, points a (now owl:deprecated) legislative candidate change to the base/transform construct that received the enacted change through the governed, append-only graduation migration.")
AnnotationAssertion(rdfs:label rwxh:graduatedTo "graduated to")
AnnotationAssertion(skos:definition rwxh:graduatedTo "Points an enacted, graduated candidate change to the base/transform construct that received the change.")

# Annotation Property: rwxh:impactAssessment (impact assessment)

AnnotationAssertion(obo:IAO_0000115 rwxh:impactAssessment "The analytic narrative of the downstream effect the proposal would have on the acquisition process if enacted -- the product of the horizon layer.")
AnnotationAssertion(rdfs:label rwxh:impactAssessment "impact assessment")
AnnotationAssertion(skos:definition rwxh:impactAssessment "The analytic narrative of the downstream effect the proposal would have if enacted.")

# Annotation Property: rwxh:legislativeMaturity (legislative maturity)

AnnotationAssertion(obo:IAO_0000115 rwxh:legislativeMaturity "The rung a legislative candidate change occupies on the legislative-maturity ladder, taken from the Congress.gov API's real status: one of proposed | introduced | reported | passed-one-chamber | in-conference | enacted. On 'enacted' the candidate graduates out of the horizon into transform/base with statutory provenance.")
AnnotationAssertion(rdfs:label rwxh:legislativeMaturity "legislative maturity")
AnnotationAssertion(skos:definition rwxh:legislativeMaturity "The legislative-maturity rung (proposed | introduced | reported | passed-one-chamber | in-conference | enacted), taken from the source's real status.")

# Annotation Property: rwxh:likelihoodBasis (likelihood basis)

AnnotationAssertion(obo:IAO_0000115 rwxh:likelihoodBasis "The sourced rationale for an enactmentLikelihood judgment; a likelihood is never a bare value.")
AnnotationAssertion(rdfs:label rwxh:likelihoodBasis "likelihood basis")
AnnotationAssertion(skos:definition rwxh:likelihoodBasis "The sourced rationale for an enactmentLikelihood judgment.")

# Annotation Property: rwxh:prospectiveAuthorityTier (prospective authority tier)

AnnotationAssertion(obo:IAO_0000115 rwxh:prospectiveAuthorityTier "The authority tier a legislative candidate change WOULD establish if enacted -- e.g. STATUTE-PENDING (a pending statute). This is a horizon-layer annotation about a proposal; it is distinct from the transform layer's rwxt:authorityTier, which records the ASSERTED authority basis of an in-effect construct. Keeping them separate preserves the prospective-vs-asserted boundary. On enactment the construct gains rwxt:authorityTier via the graduation migration, not this property.")
AnnotationAssertion(rdfs:label rwxh:prospectiveAuthorityTier "prospective authority tier")
AnnotationAssertion(skos:definition rwxh:prospectiveAuthorityTier "The authority tier a legislative candidate change would establish if enacted (e.g. STATUTE-PENDING); distinct from the transform layer's asserted authorityTier.")


############################
#   Object Properties
############################

# Object Property: prov:wasDerivedFrom (was derived from)

AnnotationAssertion(obo:IAO_0000115 prov:wasDerivedFrom "PROV-O: relates a legislative candidate change to the legislative instrument (bill, report, or public law) whose text it was extracted from.")
AnnotationAssertion(rdfs:label prov:wasDerivedFrom "was derived from")

# Object Property: rwxh:wouldAffect (would affect)

AnnotationAssertion(obo:IAO_0000115 rwxh:wouldAffect "Relates a legislative candidate change to the existing base or transform construct it would ADD to, MODIFY, or SUPERSEDE if the proposal were enacted. This is an INTENSIONAL reference for analysis only: it asserts NO change to the referenced construct. It is deliberately NOT a subproperty of any base relation and carries no range axiom, so a reasoner infers nothing about the referenced construct. The target construct is referenced by its class IRI via OWL 2 punning (a class name used as an individual).")
AnnotationAssertion(rdfs:label rwxh:wouldAffect "would affect")
AnnotationAssertion(skos:definition rwxh:wouldAffect "Relates a legislative candidate change to the base/transform construct it would add to, modify, or supersede if enacted; an intensional reference that asserts no change to the target.")
ObjectPropertyDomain(rwxh:wouldAffect rwxh:LegislativeCandidateChange)



############################
#   Classes
############################

# Class: rwxa:AcquisitionGate (Acquisition Gate)

DisjointClasses(rwxa:AcquisitionGate rwxh:LegislativeCandidateChange)

# Class: rwxa:AcquisitionMilestone (Acquisition Milestone)

DisjointClasses(rwxa:AcquisitionMilestone rwxh:LegislativeCandidateChange)

# Class: rwxa:AcquisitionPhase (Acquisition Phase)

DisjointClasses(rwxa:AcquisitionPhase rwxh:LegislativeCandidateChange)

# Class: rwxa:FundingSource (Funding Source)

DisjointClasses(rwxa:FundingSource rwxh:LegislativeCandidateChange)

# Class: rwxa:ProgramOversightOrganization (Program Oversight Organization)

DisjointClasses(rwxa:ProgramOversightOrganization rwxh:LegislativeCandidateChange)

# Class: rwxa:RequirementDeterminationProcess (Requirement Determination Process)

DisjointClasses(rwxa:RequirementDeterminationProcess rwxh:LegislativeCandidateChange)

# Class: rwxa:TechnicalReview (Technical Review)

DisjointClasses(rwxa:TechnicalReview rwxh:LegislativeCandidateChange)

# Class: rwxh:LegislativeCandidateChange (Legislative Candidate Change)

AnnotationAssertion(obo:IAO_0000115 rwxh:LegislativeCandidateChange "A descriptive information content entity that DESCRIBES a proposed, not-yet-in-effect change to the defense acquisition system, extracted from a specific legislative instrument. EPISTEMIC DISCIPLINE: asserting an instance of this class asserts ONLY that the proposal exists and what it describes -- it does NOT assert that the described change is in effect. Prospective is not asserted.")
AnnotationAssertion(rdfs:isDefinedBy rwxh:LegislativeCandidateChange <https://w3id.org/rockworx/acq/horizon>)
AnnotationAssertion(rdfs:label rwxh:LegislativeCandidateChange "Legislative Candidate Change")
AnnotationAssertion(skos:definition rwxh:LegislativeCandidateChange "A descriptive information content entity describing a proposed, not-yet-in-effect change to the defense acquisition system, extracted from a specific legislative instrument; prospective, never asserted as in effect.")
SubClassOf(rwxh:LegislativeCandidateChange cco:ont00000853)
DisjointClasses(rwxh:LegislativeCandidateChange rwxh:LegislativeInstrument)

# Class: rwxh:LegislativeInstrument (Legislative Instrument)

AnnotationAssertion(obo:IAO_0000115 rwxh:LegislativeInstrument "A document content entity that is a bill, amendment, committee report, or enacted public law before or passed by the United States Congress (e.g. H.R. 3838, S. 4784, Public Law 119-60). Its existence is a matter of public record; asserting it asserts only that the document exists.")
AnnotationAssertion(rdfs:isDefinedBy rwxh:LegislativeInstrument <https://w3id.org/rockworx/acq/horizon>)
AnnotationAssertion(rdfs:label rwxh:LegislativeInstrument "Legislative Instrument")
AnnotationAssertion(skos:definition rwxh:LegislativeInstrument "A document content entity that is a bill, amendment, committee report, or enacted public law before or passed by the United States Congress.")
SubClassOf(rwxh:LegislativeInstrument cco:ont00002039)


)