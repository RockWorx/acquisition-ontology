        <obo:IAO_0000115>An organization that is the legacy program-executive office, reorganized under the Defense Acquisition System reform into Portfolio Acquisition Executive portfolios.</obo:IAO_0000115>
        <obo:IAO_0100001 rdf:resource="https://w3id.org/rockworx/acq/transform#PortfolioAcquisitionExecutive"/>
