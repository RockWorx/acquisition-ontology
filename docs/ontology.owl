        <terms:creator>RockWorx Aerospace</terms:creator>
        <terms:license rdf:resource="https://opensource.org/licenses/BSD-3-Clause"/>
        <rdfs:label>RockWorx Acquisition Transformation Overlay</rdfs:label>
        <owl:versionInfo>2026-07-18</owl:versionInfo>
        <skos:definition>The transformation overlay ontology: reformed and legacy fillers of the base RWXA acquisition-lifecycle roles, linked by deprecation and provenance to the Defense Acquisition System reform of 2025.</skos:definition>
    </owl:Ontology>
    


