    <owl:Ontology rdf:about="https://w3id.org/rockworx/acq/transform">
        <owl:versionIRI rdf:resource="https://w3id.org/rockworx/acq/transform/2026-07-18"/>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/iao.owl"/>
