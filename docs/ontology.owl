    <rdf:Description rdf:about="https://w3id.org/rockworx/acq/transform#KeyOperationalProblem">
        <obo:IAO_0000115>An objective that is a prioritized joint-force operational problem ranked by the re-oriented Joint Requirements Oversight Council (JROC); the requirements root that replaced JCIDS capability documents.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
