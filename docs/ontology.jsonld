    "@value" : "An organization that is the single accountable portfolio office under the Defense Acquisition System reform, holding acquisition authority across a capability portfolio in place of a program-by-program Program Executive Office."
  } ],
  "http://www.w3.org/ns/prov#wasDerivedFrom" : [ {
    "@id" : "https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"
  } ],
