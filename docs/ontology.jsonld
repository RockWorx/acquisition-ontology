  "@id" : "http://www.w3.org/ns/prov#wasDerivedFrom",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "PROV-O: relates a legislative candidate change to the legislative instrument (bill, report, or public law) whose text it was extracted from."
  }, {
    "@value" : "PROV-O: the subject entity was derived from the object entity. Reused here (NOT minted) so that a requirement or KPP traces to the statutory or policy authority that establishes it; declared locally only so the tag-library generator emits its connection def."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Reused from PROV-O for requirement-to-authority tracing; not a RockWorx-minted property."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "was derived from"
  } ]
}, {
  "@id" : "https://w3id.org/rockworx/acq",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "RockWorx Aerospace"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "A BFO/CCO-conformant ontology of the U.S. DoD acquisition lifecycle in four modules: the base (DoDI 5000.85 Major Capability Acquisition -- what IS law/policy), the transformation overlay (the 2025 Warfighting Acquisition System / Joint Force Requirements Process reform), the legislative-horizon layer (what MIGHT become law -- pending bills as non-asserted candidate changes), and the SysML v2 link bridge. Creator: RockWorx Aerospace. License: BSD-3-Clause."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://opensource.org/licenses/BSD-3-Clause"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "RockWorx Acquisition Ontology"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "RockWorx Acquisition Ontology"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/rockworx/acq/2026-07-18"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "2026-07-18"
  } ]
}, {
  "@id" : "https://w3id.org/rockworx/acq#AcquisitionGate",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A planned decision act by which a Milestone Decision Authority authorizes passage from one acquisition phase to the next (e.g. a Milestone A/B/C decision or an MRL gate); it creates a prescriptive information content entity (an acquisition decision memorandum)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/rockworx/acq"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Acquisition Gate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.commoncoreontologies.org/ont00000228"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/rockworx/acq#TechnicalReview"
  }, {
    "@id" : "https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "A planned decision act by which a Milestone Decision Authority authorizes passage from one acquisition phase to the next (e.g. a Milestone A/B/C decision or an MRL gate); it creates a prescriptive information content entity (an acquisition decision memorandum)."
  } ]
}, {
  "@id" : "https://w3id.org/rockworx/acq#AcquisitionMilestone",
