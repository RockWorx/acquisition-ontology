  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "A planned process that is the Joint Force Requirements Process (JFRP) that replaced JCIDS; under it the re-oriented Joint Requirements Oversight Council (JROC) ranks Key Operational Problems rather than validating prescriptive capability documents."
  } ],
  "http://www.w3.org/ns/prov#wasDerivedFrom" : [ {
    "@id" : "https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"
