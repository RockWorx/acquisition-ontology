    "@value" : "An objective that is a prioritized joint-force operational problem ranked by the re-oriented Joint Requirements Oversight Council (JROC); the requirements root that replaced JCIDS capability documents."
  } ],
  "http://www.w3.org/ns/prov#wasDerivedFrom" : [ {
    "@id" : "https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"
  } ],
  "https://w3id.org/rockworx/acq/transform#authorityTier" : [ {
    "@value" : "POLICY"
  } ]
