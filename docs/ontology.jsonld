    "@value" : "A document content entity that is the Defense Acquisition System reform's data-driven portfolio performance record, whose primary measure is time-to-field."
  } ],
  "http://www.w3.org/ns/prov#wasDerivedFrom" : [ {
    "@id" : "https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"
  } ],
