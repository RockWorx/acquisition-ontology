  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A process during which a defined set of DoD acquisition activities occurs (e.g. MSA, TMRR, EMD, P&D, O&S); it occupies a one-dimensional temporal region."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
