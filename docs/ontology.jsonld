  "http://purl.obolibrary.org/obo/IAO_0000115" : [ {
    "@value" : "A process boundary marking a decision point in the acquisition lifecycle (Milestone A, B, or C)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://w3id.org/rockworx/acq"
  } ],
