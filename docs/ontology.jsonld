    "@value" : "Acquisition Gate"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.commoncoreontologies.org/ont00000228"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/rockworx/acq#TechnicalReview"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@value" : "A planned decision act by which a Milestone Decision Authority authorizes passage from one acquisition phase to the next (e.g. a Milestone A/B/C decision or an MRL gate); it creates a prescriptive information content entity (an acquisition decision memorandum)."
  } ]
}, {
