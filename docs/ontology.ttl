                rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000853> ;
                <http://purl.obolibrary.org/obo/IAO_0000115> "A descriptive information content entity that describes a program risk and bears likelihood and consequence qualities." ;
                rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                rdfs:label "Risk Assessment" ;
                <http://www.w3.org/2004/02/skos/core#definition> "A descriptive information content entity that describes a program risk and bears likelihood and consequence qualities." .


###  https://w3id.org/rockworx/acq#TechnicalReview
:TechnicalReview rdf:type owl:Class ;
                 rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000228> ;
                 owl:disjointWith <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
                 <http://purl.obolibrary.org/obo/IAO_0000115> "A planned act by which the technical state of a program is assessed against defined entry and exit criteria (e.g. SRR, PDR, CDR, TRR); it creates a descriptive information content entity (the review findings) and informs an acquisition gate." ;
                 rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                 rdfs:label "Technical Review" ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A planned act by which the technical state of a program is assessed against defined entry and exit criteria (e.g. SRR, PDR, CDR, TRR); it creates a descriptive information content entity (the review findings) and informs an acquisition gate." .


###  https://w3id.org/rockworx/acq#UndesiredProgrammaticProcess
:UndesiredProgrammaticProcess rdf:type owl:Class ;
                              rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                              <http://purl.obolibrary.org/obo/IAO_0000115> "A programmatic process constituting an undesired outcome that a program risk is realized in." ;
                              rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                              rdfs:label "Undesired Programmatic Process" ;
                              <http://www.w3.org/2004/02/skos/core#definition> "A programmatic process constituting an undesired outcome that a program risk is realized in." .


###  https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange
<https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000853> ;
                                                                   owl:disjointWith <https://w3id.org/rockworx/acq/horizon#LegislativeInstrument> ;
                                                                   <http://purl.obolibrary.org/obo/IAO_0000115> "A descriptive information content entity that DESCRIBES a proposed, not-yet-in-effect change to the defense acquisition system, extracted from a specific legislative instrument. EPISTEMIC DISCIPLINE: asserting an instance of this class asserts ONLY that the proposal exists and what it describes -- it does NOT assert that the described change is in effect. Prospective is not asserted." ;
                                                                   rdfs:isDefinedBy <https://w3id.org/rockworx/acq/horizon> ;
                                                                   rdfs:label "Legislative Candidate Change" ;
                                                                   <http://www.w3.org/2004/02/skos/core#definition> "A descriptive information content entity describing a proposed, not-yet-in-effect change to the defense acquisition system, extracted from a specific legislative instrument; prospective, never asserted as in effect." .


###  https://w3id.org/rockworx/acq/horizon#LegislativeInstrument
<https://w3id.org/rockworx/acq/horizon#LegislativeInstrument> rdf:type owl:Class ;
                                                              rdfs:subClassOf <https://www.commoncoreontologies.org/ont00002039> ;
                                                              <http://purl.obolibrary.org/obo/IAO_0000115> "A document content entity that is a bill, amendment, committee report, or enacted public law before or passed by the United States Congress (e.g. H.R. 3838, S. 4784, Public Law 119-60). Its existence is a matter of public record; asserting it asserts only that the document exists." ;
                                                              rdfs:isDefinedBy <https://w3id.org/rockworx/acq/horizon> ;
                                                              rdfs:label "Legislative Instrument" ;
                                                              <http://www.w3.org/2004/02/skos/core#definition> "A document content entity that is a bill, amendment, committee report, or enacted public law before or passed by the United States Congress." .


