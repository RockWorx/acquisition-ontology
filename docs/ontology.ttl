@prefix : <https://w3id.org/rockworx/acq#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/rockworx/acq#> .

<https://w3id.org/rockworx/acq> rdf:type owl:Ontology ;
                                 <http://purl.org/dc/terms/creator> "RockWorx Aerospace" ;
                                 <http://purl.org/dc/terms/description> "A BFO/CCO-conformant ontology of the U.S. DoD acquisition lifecycle (DoDI 5000.85) and its 2025 WAS/JFRP reform, with a working SysML v2 integration." ;
                                 <http://purl.org/dc/terms/license> <https://opensource.org/licenses/BSD-3-Clause> ;
                                 <http://purl.org/dc/terms/title> "RockWorx Acquisition Ontology + SysML v2 Link" ;
                                 owl:versionInfo "2026-07-19" .

