<https://w3id.org/rockworx/acq/transform> rdf:type owl:Ontology ;
                                           owl:versionIRI <https://w3id.org/rockworx/acq/transform/2026-07-18> ;
                                           owl:imports <http://purl.obolibrary.org/obo/iao.owl> ,
                                                       <https://w3id.org/rockworx/acq> ;
                                           <http://purl.org/dc/terms/creator> "RockWorx Aerospace" ;
                                           <http://purl.org/dc/terms/license> <https://opensource.org/licenses/BSD-3-Clause> ;
                                           rdfs:label "RockWorx Acquisition Transformation Overlay" ;
                                           owl:versionInfo "2026-07-18" ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "The transformation overlay ontology: reformed and legacy fillers of the base RWXA acquisition-lifecycle roles, linked by deprecation and provenance to the Defense Acquisition System reform of 2025." .

