###  https://w3id.org/rockworx/acq#FundingSource
<https://w3id.org/rockworx/acq#FundingSource> rdf:type owl:Class .


###  https://w3id.org/rockworx/acq#ProgramOversightOrganization
<https://w3id.org/rockworx/acq#ProgramOversightOrganization> rdf:type owl:Class .


###  https://w3id.org/rockworx/acq#RequirementDeterminationProcess
<https://w3id.org/rockworx/acq#RequirementDeterminationProcess> rdf:type owl:Class .


###  https://w3id.org/rockworx/acq/transform#CapabilityTradeCouncil
:CapabilityTradeCouncil rdf:type owl:Class ;
                        rdfs:subClassOf <https://www.commoncoreontologies.org/ont00001180> ;
                        rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                        rdfs:label "Capability Trade Council" ;
                        <http://www.w3.org/2004/02/skos/core#definition> "An organization that replaces configuration steering boards, integrating operational and acquisition authorities into a single body that adjudicates requirement-versus-cost trades for a capability portfolio." ;
                        <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                        :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#ConfigurationSteeringBoard
:ConfigurationSteeringBoard rdf:type owl:Class ;
                            rdfs:subClassOf <https://www.commoncoreontologies.org/ont00001180> ;
                            <http://purl.obolibrary.org/obo/IAO_0100001> :CapabilityTradeCouncil ;
                            rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                            rdfs:label "Configuration Steering Board" ;
                            owl:deprecated "true"^^xsd:boolean ;
                            <http://www.w3.org/2004/02/skos/core#definition> "An organization that is the legacy board responsible for requirement-versus-cost trades on a single program, replaced by capability trade councils operating at the portfolio level." .


###  https://w3id.org/rockworx/acq/transform#DefenseAcquisitionSystemReform
:DefenseAcquisitionSystemReform rdf:type owl:Class ;
                                rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000228> ;
                                rdfs:label "Defense Acquisition System Reform" .


###  https://w3id.org/rockworx/acq/transform#InitialCapabilitiesDocument
:InitialCapabilitiesDocument rdf:type owl:Class ;
                             rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000965> ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <https://w3id.org/rockworx/acq#isRequirementsInputTo> ;
                                               owl:someValuesFrom :JCIDS
                                             ] ;
                             <http://purl.obolibrary.org/obo/IAO_0100001> :KeyOperationalProblem ;
                             rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                             rdfs:label "Initial Capabilities Document" ;
                             owl:deprecated "true"^^xsd:boolean ;
                             <http://www.w3.org/2004/02/skos/core#definition> "A prescriptive information content entity that is the legacy JCIDS document prescribing a capability requirement, identifying a capability gap and a preferred materiel approach." .


###  https://w3id.org/rockworx/acq/transform#JCIDS
:JCIDS rdf:type owl:Class ;
       rdfs:subClassOf <https://w3id.org/rockworx/acq#RequirementDeterminationProcess> ;
       <http://purl.obolibrary.org/obo/IAO_0100001> :JointForceRequirementsProcess ;
       rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
       rdfs:label "Joint Capabilities Integration and Development System" ;
       owl:deprecated "true"^^xsd:boolean ;
       <http://www.w3.org/2004/02/skos/core#definition> "A planned process that is the disestablished pre-2025 joint requirements process by which capability requirements were determined via prescriptive capability documents." .


###  https://w3id.org/rockworx/acq/transform#JointAccelerationReserve
:JointAccelerationReserve rdf:type owl:Class ;
                          rdfs:subClassOf <https://w3id.org/rockworx/acq#FundingSource> ;
                          rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                          rdfs:label "Joint Acceleration Reserve" ;
                          <http://www.w3.org/2004/02/skos/core#definition> "A funding source that is the CAPE-maintained (Cost Assessment and Program Evaluation) reserve established to address the valley of death between prototype demonstration and program of record funding." ;
                          <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                          :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#JointForceRequirementsProcess
:JointForceRequirementsProcess rdf:type owl:Class ;
                               rdfs:subClassOf <https://w3id.org/rockworx/acq#RequirementDeterminationProcess> ;
                               rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                               rdfs:label "Joint Force Requirements Process" ;
                               <http://www.w3.org/2004/02/skos/core#definition> "A planned process that is the Joint Force Requirements Process (JFRP) that replaced JCIDS; under it the re-oriented Joint Requirements Oversight Council (JROC) ranks Key Operational Problems rather than validating prescriptive capability documents." ;
                               <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                               :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#KeyOperationalProblem
:KeyOperationalProblem rdf:type owl:Class ;
                       rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000476> ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/rockworx/acq#isRequirementsInputTo> ;
                                         owl:someValuesFrom :JointForceRequirementsProcess
                                       ] ;
                       rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                       rdfs:label "Key Operational Problem" ;
                       <http://www.w3.org/2004/02/skos/core#definition> "An objective that is a prioritized joint-force operational problem ranked by the re-oriented Joint Requirements Oversight Council (JROC); the requirements root that replaced JCIDS capability documents." ;
                       <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                       :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#PortfolioAcquisitionExecutive
:PortfolioAcquisitionExecutive rdf:type owl:Class ;
                               rdfs:subClassOf <https://w3id.org/rockworx/acq#ProgramOversightOrganization> ;
                               rdfs:comment "This class represents the organizational office, not the role borne by a person." ;
                               rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                               rdfs:label "Portfolio Acquisition Executive" ;
                               <http://www.w3.org/2004/02/skos/core#definition> "An organization that is the single accountable portfolio office under the Defense Acquisition System reform, holding acquisition authority across a capability portfolio in place of a program-by-program Program Executive Office." ;
                               <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                               :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#PortfolioScorecard
:PortfolioScorecard rdf:type owl:Class ;
                    rdfs:subClassOf <https://www.commoncoreontologies.org/ont00002039> ;
                    rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                    rdfs:label "Portfolio Scorecard" ;
                    <http://www.w3.org/2004/02/skos/core#definition> "A document content entity that is the Defense Acquisition System reform's data-driven portfolio performance record, whose primary measure is time-to-field." ;
                    <http://www.w3.org/ns/prov#wasDerivedFrom> :ExecutiveOrder14265 ;
                    :authorityTier "POLICY" .


###  https://w3id.org/rockworx/acq/transform#ProgramExecutiveOffice
:ProgramExecutiveOffice rdf:type owl:Class ;
                        rdfs:subClassOf <https://w3id.org/rockworx/acq#ProgramOversightOrganization> ;
                        <http://purl.obolibrary.org/obo/IAO_0100001> :PortfolioAcquisitionExecutive ;
                        rdfs:comment "This class represents the organizational office, not the role borne by a person." ;
                        rdfs:isDefinedBy <https://w3id.org/rockworx/acq/transform> ;
                        rdfs:label "Program Executive Office" ;
                        owl:deprecated "true"^^xsd:boolean ;
                        <http://www.w3.org/2004/02/skos/core#definition> "An organization that is the legacy program-executive office, reorganized under the Defense Acquisition System reform into Portfolio Acquisition Executive portfolios." .


###  https://www.commoncoreontologies.org/ont00000228
<https://www.commoncoreontologies.org/ont00000228> rdf:type owl:Class .


