###  https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265
:ExecutiveOrder14265 rdf:type owl:NamedIndividual ,
                              <https://www.commoncoreontologies.org/ont00002039> ;
                     rdfs:label "Executive Order 14265" .


###  https://w3id.org/rockworx/acq/transform#establishedPortfolioAcquisitionExecutives
:establishedPortfolioAcquisitionExecutives rdf:type owl:NamedIndividual ,
                                                    :PortfolioAcquisitionExecutive ;
                                           rdfs:label "The established Portfolio Acquisition Executives" .


###  https://w3id.org/rockworx/acq/transform#reorganizedProgramExecutiveOffices
:reorganizedProgramExecutiveOffices rdf:type owl:NamedIndividual ,
                                             :ProgramExecutiveOffice ;
                                    rdfs:label "The reorganized Program Executive Offices" .


