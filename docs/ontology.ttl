:DASReform2025 rdf:type owl:NamedIndividual ,
                        :DefenseAcquisitionSystemReform ;
               <http://purl.obolibrary.org/obo/BFO_0000057> :reorganizedProgramExecutiveOffices ;
               rdfs:comment "Temporally bounded 2025-present; directed by Executive Order 14265 (November 2025)." ;
