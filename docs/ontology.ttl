@prefix : <https://w3id.org/rockworx/acq#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/rockworx/acq#> .

<https://w3id.org/rockworx/acq> rdf:type owl:Ontology ;
                                 owl:versionIRI <https://w3id.org/rockworx/acq/2026-07-18> ;
                                 <http://purl.org/dc/terms/creator> "RockWorx Aerospace" ;
                                 <http://purl.org/dc/terms/description> "A BFO/CCO-conformant ontology of the U.S. DoD acquisition lifecycle in four modules: the base (DoDI 5000.85 Major Capability Acquisition -- what IS law/policy), the transformation overlay (the 2025 Warfighting Acquisition System / Joint Force Requirements Process reform), the legislative-horizon layer (what MIGHT become law -- pending bills as non-asserted candidate changes), and the SysML v2 link bridge. Creator: RockWorx Aerospace. License: BSD-3-Clause." ;
                                 <http://purl.org/dc/terms/license> <https://opensource.org/licenses/BSD-3-Clause> ;
                                 <http://purl.org/dc/terms/title> "RockWorx Acquisition Ontology" ;
                                 rdfs:label "RockWorx Acquisition Ontology" ;
                                 owl:versionInfo "2026-07-18" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000057
<http://purl.obolibrary.org/obo/BFO_0000057> rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/IAO_0000115
<http://purl.obolibrary.org/obo/IAO_0000115> rdf:type owl:AnnotationProperty .


###  http://purl.obolibrary.org/obo/IAO_0100001
<http://purl.obolibrary.org/obo/IAO_0100001> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/date
<http://purl.org/dc/terms/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  https://w3id.org/rockworx/acq/horizon#changeType
<https://w3id.org/rockworx/acq/horizon#changeType> rdf:type owl:AnnotationProperty ;
                                                   <http://purl.obolibrary.org/obo/IAO_0000115> "What the proposal would do to the referenced construct if enacted: ADD | MODIFY | SUPERSEDE." ;
                                                   rdfs:label "change type" ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "What the proposal would do to the referenced construct if enacted: ADD | MODIFY | SUPERSEDE." .


###  https://w3id.org/rockworx/acq/horizon#enactmentLikelihood
<https://w3id.org/rockworx/acq/horizon#enactmentLikelihood> rdf:type owl:AnnotationProperty ;
                                                            <http://purl.obolibrary.org/obo/IAO_0000115> "An explicit, sourced JUDGMENT of the likelihood the proposal is enacted: LOW | MEDIUM | HIGH. This is a judgment, NEVER a fact; it is an annotation and is invisible to the reasoner. It must always be paired with a likelihoodBasis." ;
                                                            rdfs:label "enactment likelihood" ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "An explicit, sourced judgment (LOW | MEDIUM | HIGH) of the likelihood of enactment; a judgment, never a fact." .


###  https://w3id.org/rockworx/acq/horizon#graduatedTo
<https://w3id.org/rockworx/acq/horizon#graduatedTo> rdf:type owl:AnnotationProperty ;
                                                    <http://purl.obolibrary.org/obo/IAO_0000115> "On enactment, points a (now owl:deprecated) legislative candidate change to the base/transform construct that received the enacted change through the governed, append-only graduation migration." ;
                                                    rdfs:label "graduated to" ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Points an enacted, graduated candidate change to the base/transform construct that received the change." .


###  https://w3id.org/rockworx/acq/horizon#impactAssessment
<https://w3id.org/rockworx/acq/horizon#impactAssessment> rdf:type owl:AnnotationProperty ;
                                                         <http://purl.obolibrary.org/obo/IAO_0000115> "The analytic narrative of the downstream effect the proposal would have on the acquisition process if enacted -- the product of the horizon layer." ;
                                                         rdfs:label "impact assessment" ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "The analytic narrative of the downstream effect the proposal would have if enacted." .


###  https://w3id.org/rockworx/acq/horizon#legislativeMaturity
<https://w3id.org/rockworx/acq/horizon#legislativeMaturity> rdf:type owl:AnnotationProperty ;
                                                            <http://purl.obolibrary.org/obo/IAO_0000115> "The rung a legislative candidate change occupies on the legislative-maturity ladder, taken from the Congress.gov API's real status: one of proposed | introduced | reported | passed-one-chamber | in-conference | enacted. On 'enacted' the candidate graduates out of the horizon into transform/base with statutory provenance." ;
                                                            rdfs:label "legislative maturity" ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "The legislative-maturity rung (proposed | introduced | reported | passed-one-chamber | in-conference | enacted), taken from the source's real status." .


###  https://w3id.org/rockworx/acq/horizon#likelihoodBasis
<https://w3id.org/rockworx/acq/horizon#likelihoodBasis> rdf:type owl:AnnotationProperty ;
                                                        <http://purl.obolibrary.org/obo/IAO_0000115> "The sourced rationale for an enactmentLikelihood judgment; a likelihood is never a bare value." ;
                                                        rdfs:label "likelihood basis" ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "The sourced rationale for an enactmentLikelihood judgment." .


###  https://w3id.org/rockworx/acq/horizon#prospectiveAuthorityTier
<https://w3id.org/rockworx/acq/horizon#prospectiveAuthorityTier> rdf:type owl:AnnotationProperty ;
                                                                 <http://purl.obolibrary.org/obo/IAO_0000115> "The authority tier a legislative candidate change WOULD establish if enacted -- e.g. STATUTE-PENDING (a pending statute). This is a horizon-layer annotation about a proposal; it is distinct from the transform layer's rwxt:authorityTier, which records the ASSERTED authority basis of an in-effect construct. Keeping them separate preserves the prospective-vs-asserted boundary. On enactment the construct gains rwxt:authorityTier via the graduation migration, not this property." ;
                                                                 rdfs:label "prospective authority tier" ;
                                                                 <http://www.w3.org/2004/02/skos/core#definition> "The authority tier a legislative candidate change would establish if enacted (e.g. STATUTE-PENDING); distinct from the transform layer's asserted authorityTier." .


###  https://w3id.org/rockworx/acq/transform#authorityTier
<https://w3id.org/rockworx/acq/transform#authorityTier> rdf:type owl:AnnotationProperty ;
                                                        <http://purl.obolibrary.org/obo/IAO_0000115> "The level of authority -- STATUTE > POLICY > GUIDANCE -- from which an acquisition construct is derived." ;
                                                        rdfs:label "authority tier" ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "The level of authority -- STATUTE > POLICY > GUIDANCE -- from which an acquisition construct is derived." .


###  https://www.commoncoreontologies.org/ont00001921
<https://www.commoncoreontologies.org/ont00001921> rdf:type owl:AnnotationProperty .


###  https://www.commoncoreontologies.org/ont00001986
<https://www.commoncoreontologies.org/ont00001986> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/ns/prov#wasDerivedFrom
<http://www.w3.org/ns/prov#wasDerivedFrom> rdf:type owl:ObjectProperty ;
                                           <http://purl.obolibrary.org/obo/IAO_0000115> "PROV-O: relates a legislative candidate change to the legislative instrument (bill, report, or public law) whose text it was extracted from." ,
                                                                                        "PROV-O: the subject entity was derived from the object entity. Reused here (NOT minted) so that a requirement or KPP traces to the statutory or policy authority that establishes it; declared locally only so the tag-library generator emits its connection def." ;
                                           rdfs:comment "Reused from PROV-O for requirement-to-authority tracing; not a RockWorx-minted property." ;
                                           rdfs:label "was derived from" .


###  https://w3id.org/rockworx/acq#demands
:demands rdf:type owl:ObjectProperty ;
         <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an acquisition gate or technical review to a competency it demands be demonstrated for passage." ;
         rdfs:label "demands" ;
         <http://www.w3.org/2004/02/skos/core#definition> "Relates an acquisition gate or technical review to a competency it demands be demonstrated for passage." .


###  https://w3id.org/rockworx/acq#demonstrates
:demonstrates rdf:type owl:ObjectProperty ;
              <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an information artifact to a competency whose maturity it demonstrates (evidentially, carrying a date)." ;
              rdfs:label "demonstrates" ;
              <http://www.w3.org/2004/02/skos/core#definition> "Relates an information artifact to a competency whose maturity it demonstrates (evidentially, carrying a date)." .


###  https://w3id.org/rockworx/acq#gates
:gates rdf:type owl:ObjectProperty ;
       <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an acquisition gate to the phase transition whose authorization it controls." ;
       rdfs:label "gates" ;
       <http://www.w3.org/2004/02/skos/core#definition> "Relates an acquisition gate to the phase transition whose authorization it controls." .


###  https://w3id.org/rockworx/acq#governs
:governs rdf:type owl:ObjectProperty ;
         <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a program-oversight organization to a program element under its acquisition oversight." ;
         rdfs:label "governs" ;
         <http://www.w3.org/2004/02/skos/core#definition> "Relates a program-oversight organization to a program element under its acquisition oversight." .


###  https://w3id.org/rockworx/acq#informs
:informs rdf:type owl:ObjectProperty ;
         rdfs:domain :TechnicalReview ;
         rdfs:range :AcquisitionGate ;
         <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a technical review to the acquisition gate decision it informs (a review informs, but does not constitute, a gate)." ;
         rdfs:label "informs" ;
         <http://www.w3.org/2004/02/skos/core#definition> "Relates a technical review to the acquisition gate decision it informs (a review informs, but does not constitute, a gate)." .


###  https://w3id.org/rockworx/acq#isRequirementsInputTo
:isRequirementsInputTo rdf:type owl:ObjectProperty ;
                       rdfs:domain <https://www.commoncoreontologies.org/ont00000958> ;
                       rdfs:range :RequirementDeterminationProcess ;
                       <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an information artifact (a capability requirement document or an operational problem statement) to the requirement-determination process it feeds." ;
                       rdfs:label "is requirements input to" ;
                       <http://www.w3.org/2004/02/skos/core#definition> "Relates an information artifact (a capability requirement document or an operational problem statement) to the requirement-determination process it feeds." .


###  https://w3id.org/rockworx/acq#owns
:owns rdf:type owl:ObjectProperty ;
      <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an agent or role to the acquisition act (gate or review) for which it holds decision ownership." ;
      rdfs:label "owns" ;
      <http://www.w3.org/2004/02/skos/core#definition> "Relates an agent or role to the acquisition act (gate or review) for which it holds decision ownership." .


###  https://w3id.org/rockworx/acq#performs
:performs rdf:type owl:ObjectProperty ;
          <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an agent to an acquisition activity it performs." ;
          rdfs:label "performs" ;
          <http://www.w3.org/2004/02/skos/core#definition> "Relates an agent to an acquisition activity it performs." .


###  https://w3id.org/rockworx/acq#precedes
:precedes rdf:type owl:ObjectProperty ;
          <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an acquisition phase to the phase that immediately follows it in the lifecycle." ;
          rdfs:label "precedes" ;
          <http://www.w3.org/2004/02/skos/core#definition> "Relates an acquisition phase to the phase that immediately follows it in the lifecycle." .


###  https://w3id.org/rockworx/acq#producesArtifact
:producesArtifact rdf:type owl:ObjectProperty ;
                  <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an acquisition activity to an information artifact it produces." ;
                  rdfs:label "produces artifact" ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Relates an acquisition activity to an information artifact it produces." .


###  https://w3id.org/rockworx/acq#requiresArtifact
:requiresArtifact rdf:type owl:ObjectProperty ;
                  <http://purl.obolibrary.org/obo/IAO_0000115> "Relates an acquisition gate or technical review to an information artifact it requires as entry or exit criteria." ;
                  rdfs:label "requires artifact" ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Relates an acquisition gate or technical review to an information artifact it requires as entry or exit criteria." .


###  https://w3id.org/rockworx/acq#supersedes
:supersedes rdf:type owl:ObjectProperty ;
            <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a construct to a prior construct it supersedes (e.g. a reformed process superseding a legacy one)." ;
            rdfs:label "supersedes" ;
            <http://www.w3.org/2004/02/skos/core#definition> "Relates a construct to a prior construct it supersedes (e.g. a reformed process superseding a legacy one)." .


###  https://w3id.org/rockworx/acq/horizon#wouldAffect
<https://w3id.org/rockworx/acq/horizon#wouldAffect> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
                                                    <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a legislative candidate change to the existing base or transform construct it would ADD to, MODIFY, or SUPERSEDE if the proposal were enacted. This is an INTENSIONAL reference for analysis only: it asserts NO change to the referenced construct. It is deliberately NOT a subproperty of any base relation and carries no range axiom, so a reasoner infers nothing about the referenced construct. The target construct is referenced by its class IRI via OWL 2 punning (a class name used as an individual)." ;
                                                    rdfs:label "would affect" ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Relates a legislative candidate change to the base/transform construct it would add to, modify, or supersede if enacted; an intensional reference that asserts no change to the target." .


###  https://w3id.org/rockworx/acq/sysml#assessedAt
<https://w3id.org/rockworx/acq/sysml#assessedAt> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <https://www.commoncoreontologies.org/ont00000958> ;
                                                 rdfs:range :TechnicalReview ;
                                                 <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a requirement or key performance parameter to the technical review at which its satisfaction is assessed." ;
                                                 rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                 rdfs:label "assessed at" ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Relates a requirement or key performance parameter to the technical review at which its satisfaction is assessed." .


###  https://w3id.org/rockworx/acq/sysml#assessesRisk
<https://w3id.org/rockworx/acq/sysml#assessesRisk> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain :RiskAssessment ;
                                                   rdfs:range :ProgramRisk ;
                                                   <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a risk assessment (a descriptive information content entity) to the program risk (a disposition) it describes." ;
                                                   rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                   rdfs:label "assesses risk" .


###  https://w3id.org/rockworx/acq/sysml#indicatesRisk
<https://w3id.org/rockworx/acq/sysml#indicatesRisk> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                    rdfs:range :ProgramRisk ;
                                                    <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a process, such as a failed verification, to the program risk (a disposition) whose presence it indicates. Deliberately NOT BFO 'realizes' (obo:BFO_0000055): a failed test EVIDENCES the risk disposition; it does not realize it -- the risk is realized by the later undesired programmatic process." ;
                                                    rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                    rdfs:label "indicates risk" ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Relates a process, such as a failed verification, to the program risk whose presence it indicates (evidential, not BFO realization)." .


###  https://w3id.org/rockworx/acq/sysml#satisfies
<https://w3id.org/rockworx/acq/sysml#satisfies> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                                rdfs:range <https://www.commoncoreontologies.org/ont00000958> ;
                                                <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a design element (a material entity) to the requirement or key performance parameter that it satisfies." ;
                                                rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                rdfs:label "satisfies" ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "Relates a design element (a material entity) to the requirement or key performance parameter that it satisfies." .


###  https://w3id.org/rockworx/acq/sysml#verifies
<https://w3id.org/rockworx/acq/sysml#verifies> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                               rdfs:range <https://www.commoncoreontologies.org/ont00000958> ;
                                               <http://purl.obolibrary.org/obo/IAO_0000115> "Relates a verification activity (a process) to the requirement or key performance parameter whose satisfaction it establishes by evidence." ;
                                               rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                               rdfs:label "verifies" ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "Relates a verification activity (a process) to the requirement or key performance parameter whose satisfaction it establishes by evidence." .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/rockworx/acq/sysml#riskDisposition
<https://w3id.org/rockworx/acq/sysml#riskDisposition> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                      rdfs:range xsd:string ;
                                                      <http://purl.obolibrary.org/obo/IAO_0000115> "The program's handling decision for the risk arising from a verification's outcome: Open (unmitigated -- blocks a milestone gate) or Accepted (formally accepted -- does not block, and the failed result is retained)." ;
                                                      rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                      rdfs:label "risk disposition" .


###  https://w3id.org/rockworx/acq/sysml#riskSeverity
<https://w3id.org/rockworx/acq/sysml#riskSeverity> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain :RiskAssessment ;
                                                   rdfs:range xsd:string ;
                                                   <http://purl.obolibrary.org/obo/IAO_0000115> "The assessed severity a risk assessment records for the program risk it describes (LOW, MEDIUM, or HIGH)." ;
                                                   rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                   rdfs:label "risk severity" .


###  https://w3id.org/rockworx/acq/sysml#riskStatus
<https://w3id.org/rockworx/acq/sysml#riskStatus> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain :RiskAssessment ;
                                                 rdfs:range xsd:string ;
                                                 <http://purl.obolibrary.org/obo/IAO_0000115> "The management status a risk assessment records (Open, Closed, or Accepted); only an Open assessment of a risk blocks a milestone gate." ;
                                                 rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                 rdfs:label "risk status" .


###  https://w3id.org/rockworx/acq/sysml#verificationResult
<https://w3id.org/rockworx/acq/sysml#verificationResult> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                         rdfs:range xsd:string ;
                                                         <http://purl.obolibrary.org/obo/IAO_0000115> "The recorded outcome of a verification (e.g. PASS or FAIL); a FAIL is the explicit datum from which a program risk is derived." ;
                                                         rdfs:isDefinedBy <https://w3id.org/rockworx/acq/sysml> ;
                                                         rdfs:label "verification result" .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000015
<http://purl.obolibrary.org/obo/BFO_0000015> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000016
<http://purl.obolibrary.org/obo/BFO_0000016> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000035
<http://purl.obolibrary.org/obo/BFO_0000035> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000040
<http://purl.obolibrary.org/obo/BFO_0000040> rdf:type owl:Class .


###  https://w3id.org/rockworx/acq#AcquisitionGate
:AcquisitionGate rdf:type owl:Class ;
                 rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000228> ;
                 owl:disjointWith :TechnicalReview ,
                                  <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
                 <http://purl.obolibrary.org/obo/IAO_0000115> "A planned decision act by which a Milestone Decision Authority authorizes passage from one acquisition phase to the next (e.g. a Milestone A/B/C decision or an MRL gate); it creates a prescriptive information content entity (an acquisition decision memorandum)." ;
                 rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                 rdfs:label "Acquisition Gate" ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A planned decision act by which a Milestone Decision Authority authorizes passage from one acquisition phase to the next (e.g. a Milestone A/B/C decision or an MRL gate); it creates a prescriptive information content entity (an acquisition decision memorandum)." .


###  https://w3id.org/rockworx/acq#AcquisitionMilestone
:AcquisitionMilestone rdf:type owl:Class ;
                      rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000035> ;
                      owl:disjointWith <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
                      <http://purl.obolibrary.org/obo/IAO_0000115> "A process boundary marking a decision point in the acquisition lifecycle (Milestone A, B, or C)." ;
                      rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                      rdfs:label "Acquisition Milestone" ;
                      <http://www.w3.org/2004/02/skos/core#definition> "A process boundary marking a decision point in the acquisition lifecycle (Milestone A, B, or C)." .


###  https://w3id.org/rockworx/acq#AcquisitionPhase
:AcquisitionPhase rdf:type owl:Class ;
                  rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                  owl:disjointWith <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
                  <http://purl.obolibrary.org/obo/IAO_0000115> "A process during which a defined set of DoD acquisition activities occurs (e.g. MSA, TMRR, EMD, P&D, O&S); it occupies a one-dimensional temporal region." ;
                  rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                  rdfs:label "Acquisition Phase" ;
                  <http://www.w3.org/2004/02/skos/core#definition> "A process during which a defined set of DoD acquisition activities occurs (e.g. MSA, TMRR, EMD, P&D, O&S); it occupies a one-dimensional temporal region." .


###  https://w3id.org/rockworx/acq#AuthorityReference
:AuthorityReference rdf:type owl:Class ;
                    rdfs:subClassOf <https://www.commoncoreontologies.org/ont00002039> ;
                    <http://purl.obolibrary.org/obo/IAO_0000115> "A document content entity that establishes statutory or policy authority (e.g. a Title 10 U.S.C. section, a DoD instruction) to which a capability requirement or key performance parameter traces." ;
                    rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                    rdfs:label "Authority Reference" ;
                    <http://www.w3.org/2004/02/skos/core#definition> "A document content entity that establishes statutory or policy authority (e.g. a Title 10 U.S.C. section, a DoD instruction) to which a capability requirement or key performance parameter traces." .


###  https://w3id.org/rockworx/acq#FundingSource
:FundingSource rdf:type owl:Class ;
               rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000958> ;
               owl:disjointWith <https://w3id.org/rockworx/acq/horizon#LegislativeCandidateChange> ;
               <http://purl.obolibrary.org/obo/IAO_0000115> "An information content entity representing a source of program funding, such as a Joint Acceleration Reserve allocation or a PPBE program element." ;
               rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
               rdfs:label "Funding Source" ;
               <http://www.w3.org/2004/02/skos/core#definition> "An information content entity representing a source of program funding, such as a Joint Acceleration Reserve allocation or a PPBE program element." .


###  https://w3id.org/rockworx/acq#KeyPerformanceParameter
:KeyPerformanceParameter rdf:type owl:Class ;
                         rdfs:subClassOf <https://www.commoncoreontologies.org/ont00000127> ;
                         <http://purl.obolibrary.org/obo/IAO_0000115> "A performance specification stating a minimum acceptable value of a system attribute that must be met to deliver the required operational capability (a KPP); a subtype of Performance Specification that persists across the JCIDS-to-JFRP reform (KPP/KSA/APA)." ;
                         rdfs:isDefinedBy <https://w3id.org/rockworx/acq> ;
                         rdfs:label "Key Performance Parameter" ;
                         <http://www.w3.org/2004/02/skos/core#definition> "A performance specification stating a minimum acceptable value of a system attribute that must be met to deliver the required operational capability (a KPP); a subtype of Performance Specification that persists across the JCIDS-to-JFRP reform (KPP/KSA/APA)." .


