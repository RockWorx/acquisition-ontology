    <!-- https://w3id.org/rockworx/acq/transform#CapabilityTradeCouncil -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#CapabilityTradeCouncil">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001180"/>
        <obo:IAO_0000115>An organization that replaces configuration steering boards, integrating operational and acquisition authorities into a single body that adjudicates requirement-versus-cost trades for a capability portfolio.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Capability Trade Council</rdfs:label>
        <skos:definition>An organization that replaces configuration steering boards, integrating operational and acquisition authorities into a single body that adjudicates requirement-versus-cost trades for a capability portfolio.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#ConfigurationSteeringBoard -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#ConfigurationSteeringBoard">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00001180"/>
        <obo:IAO_0000115>An organization that is the legacy board responsible for requirement-versus-cost trades on a single program, replaced by capability trade councils operating at the portfolio level.</obo:IAO_0000115>
        <obo:IAO_0100001 rdf:resource="https://w3id.org/rockworx/acq/transform#CapabilityTradeCouncil"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Configuration Steering Board</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition>An organization that is the legacy board responsible for requirement-versus-cost trades on a single program, replaced by capability trade councils operating at the portfolio level.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#DefenseAcquisitionSystemReform -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#DefenseAcquisitionSystemReform">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000228"/>
        <obo:IAO_0000115>A planned process type whose instances are domain-level Defense Acquisition System reforms (e.g. DASReform2025), each directed by an authorizing instrument and reorganizing program-oversight authority across the acquisition enterprise.</obo:IAO_0000115>
        <rdfs:label>Defense Acquisition System Reform</rdfs:label>
        <skos:definition>A planned process type whose instances are domain-level Defense Acquisition System reforms (e.g. DASReform2025), each directed by an authorizing instrument and reorganizing program-oversight authority across the acquisition enterprise.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#InitialCapabilitiesDocument -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#InitialCapabilitiesDocument">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000965"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/rockworx/acq#isRequirementsInputTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/rockworx/acq/transform#JCIDS"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A prescriptive information content entity that is the legacy JCIDS document prescribing a capability requirement, identifying a capability gap and a preferred materiel approach.</obo:IAO_0000115>
        <obo:IAO_0100001 rdf:resource="https://w3id.org/rockworx/acq/transform#KeyOperationalProblem"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Initial Capabilities Document</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition>A prescriptive information content entity that is the legacy JCIDS document prescribing a capability requirement, identifying a capability gap and a preferred materiel approach.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#JCIDS -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#JCIDS">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rockworx/acq#RequirementDeterminationProcess"/>
        <obo:IAO_0000115>A planned process that is the disestablished pre-2025 joint requirements process by which capability requirements were determined via prescriptive capability documents.</obo:IAO_0000115>
        <obo:IAO_0100001 rdf:resource="https://w3id.org/rockworx/acq/transform#JointForceRequirementsProcess"/>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Joint Capabilities Integration and Development System</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition>A planned process that is the disestablished pre-2025 joint requirements process by which capability requirements were determined via prescriptive capability documents.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#JointAccelerationReserve -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#JointAccelerationReserve">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rockworx/acq#FundingSource"/>
        <obo:IAO_0000115>A funding source that is the CAPE-maintained (Cost Assessment and Program Evaluation) reserve established to address the valley of death between prototype demonstration and program of record funding.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Joint Acceleration Reserve</rdfs:label>
        <skos:definition>A funding source that is the CAPE-maintained (Cost Assessment and Program Evaluation) reserve established to address the valley of death between prototype demonstration and program of record funding.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#JointForceRequirementsProcess -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#JointForceRequirementsProcess">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rockworx/acq#RequirementDeterminationProcess"/>
        <obo:IAO_0000115>A planned process that is the Joint Force Requirements Process (JFRP) that replaced JCIDS; under it the re-oriented Joint Requirements Oversight Council (JROC) ranks Key Operational Problems rather than validating prescriptive capability documents.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Joint Force Requirements Process</rdfs:label>
        <skos:definition>A planned process that is the Joint Force Requirements Process (JFRP) that replaced JCIDS; under it the re-oriented Joint Requirements Oversight Council (JROC) ranks Key Operational Problems rather than validating prescriptive capability documents.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#KeyOperationalProblem -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#KeyOperationalProblem">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00000476"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/rockworx/acq#isRequirementsInputTo"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/rockworx/acq/transform#JointForceRequirementsProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An objective that is a prioritized joint-force operational problem ranked by the re-oriented Joint Requirements Oversight Council (JROC); the requirements root that replaced JCIDS capability documents.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Key Operational Problem</rdfs:label>
        <skos:definition>An objective that is a prioritized joint-force operational problem ranked by the re-oriented Joint Requirements Oversight Council (JROC); the requirements root that replaced JCIDS capability documents.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#PortfolioAcquisitionExecutive -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#PortfolioAcquisitionExecutive">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rockworx/acq#ProgramOversightOrganization"/>
        <obo:IAO_0000115>An organization that is the single accountable portfolio office under the Defense Acquisition System reform, holding acquisition authority across a capability portfolio in place of a program-by-program Program Executive Office.</obo:IAO_0000115>
        <rdfs:comment>This class represents the organizational office, not the role borne by a person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Portfolio Acquisition Executive</rdfs:label>
        <skos:definition>An organization that is the single accountable portfolio office under the Defense Acquisition System reform, holding acquisition authority across a capability portfolio in place of a program-by-program Program Executive Office.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#PortfolioScorecard -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#PortfolioScorecard">
        <rdfs:subClassOf rdf:resource="https://www.commoncoreontologies.org/ont00002039"/>
        <obo:IAO_0000115>A document content entity that is the Defense Acquisition System reform&apos;s data-driven portfolio performance record, whose primary measure is time-to-field.</obo:IAO_0000115>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Portfolio Scorecard</rdfs:label>
        <skos:definition>A document content entity that is the Defense Acquisition System reform&apos;s data-driven portfolio performance record, whose primary measure is time-to-field.</skos:definition>
        <prov:wasDerivedFrom rdf:resource="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265"/>
        <authorityTier>POLICY</authorityTier>
    </owl:Class>
    


    <!-- https://w3id.org/rockworx/acq/transform#ProgramExecutiveOffice -->

    <owl:Class rdf:about="https://w3id.org/rockworx/acq/transform#ProgramExecutiveOffice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/rockworx/acq#ProgramOversightOrganization"/>
        <obo:IAO_0000115>An organization that is the legacy program-executive office, reorganized under the Defense Acquisition System reform into Portfolio Acquisition Executive portfolios.</obo:IAO_0000115>
        <obo:IAO_0100001 rdf:resource="https://w3id.org/rockworx/acq/transform#PortfolioAcquisitionExecutive"/>
        <rdfs:comment>This class represents the organizational office, not the role borne by a person.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/rockworx/acq/transform"/>
        <rdfs:label>Program Executive Office</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition>An organization that is the legacy program-executive office, reorganized under the Defense Acquisition System reform into Portfolio Acquisition Executive portfolios.</skos:definition>
    </owl:Class>
    


