    </owl:NamedIndividual>
    


    <!-- https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/rockworx/acq/transform#ExecutiveOrder14265">
