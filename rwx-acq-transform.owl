    <!-- https://w3id.org/rockworx/acq/transform#DASReform2025 -->

    <owl:NamedIndividual rdf:about="https://w3id.org/rockworx/acq/transform#DASReform2025">
        <rdf:type rdf:resource="https://w3id.org/rockworx/acq/transform#DefenseAcquisitionSystemReform"/>
        <obo:BFO_0000057 rdf:resource="https://w3id.org/rockworx/acq/transform#reorganizedProgramExecutiveOffices"/>
